{
  "manifest_version": 3,
  "name": "Zenith AdBlocker — Ad Blocker & Privacy Guard",
  "version": "1.1",
  "author": "roshanxcvi",
  "description": "The ultimate ad blocker by roshanxcvi. Blocks ads, trackers, fingerprinting, crypto miners, cookie popups & annoyances. Compatible with Chrome Zero acceptable ads.",
  "minimum_chrome_version": "110",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "contextMenus",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "default_rules",
        "enabled": true,
        "path": "rules/static-rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fingerprint.js",
        "redirects/google-analytics.js",
        "redirects/googletagservices.js",
        "redirects/fbevents.js",
        "network-logger.html",
        "network-logger.js",
        "modules/procedural-filters.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
